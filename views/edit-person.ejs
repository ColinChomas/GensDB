<!DOCTYPE html>
<html>
<head>
  <title>Edit Person</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
  <style>
    .select2-container--default .select2-selection--single {
      border: 1px solid #ccc;
      padding: 3px;
      display: flex;
      align-items: center;
    }
    .select2-container--default .select2-selection--single .select2-selection__rendered {
      padding: 2px;
      display: flex;
      align-items: center;
      min-height: 30px;
    }
  </style>
</head>
<body>
  <h1>Edit Person</h1>

  <form method="POST" action="/people/edit/<%= person.id %>">

    <label>Praenomen:</label><br>
    <input type="text" name="praenomen" value="<%= person.praenomen %>" required><br><br>

    <label>House:</label><br>
    <select name="house_id" class="searchable-select">
      <% houses.forEach(h => { %>
        <option value="<%= h.id %>" <%= h.id === person.house_id ? 'selected' : '' %>>
          <%= h.gens_name %>
        </option>
      <% }) %>
    </select><br><br>

    <label>Sex:</label><br>
    <select name="sex">
      <option value="1" <%= person.sex === 1 ? 'selected' : '' %>>Male</option>
      <option value="0" <%= person.sex === 0 ? 'selected' : '' %>>Female</option>
    </select><br><br>

    <label>Cognomen:</label><br>
    <input type="text" name="cognomen" value="<%= person.cognomen || '' %>"><br><br>

    <label>Birth Year:</label><br>
    <input type="number" name="birth_year" value="<%= person.birth_year || '' %>"><br><br>

    <label>Death Year:</label><br>
    <input type="number" name="death_year" value="<%= person.death_year || '' %>"><br><br>

    <label>
      <input type="checkbox" name="is_bastard" <%= person.is_bastard ? 'checked' : '' %>>
      Bastard (hide last name in displays)
    </label><br><br>

    <h3>Parents</h3>

    <label>Father:</label><br>
    <select name="father_id" class="searchable-select">
      <option value="">None</option>
      <% people.filter(p => p.sex === 1).forEach(p => { %>
        <% const fatherNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, 1)}`; %>
        <option value="<%= p.id %>" <%= father && father.id === p.id ? 'selected' : '' %>>
          <%= `${p.praenomen}${fatherNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
          <% if (p.birth_year) { %> (<%= p.birth_year %>) <% } %>
        </option>
      <% }) %>
    </select><br><br>

    <label>Mother:</label><br>
    <select name="mother_id" class="searchable-select">
      <option value="">None</option>
      <% people.filter(p => p.sex === 0).forEach(p => { %>
        <% const motherNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, 0)}`; %>
        <option value="<%= p.id %>" <%= mother && mother.id === p.id ? 'selected' : '' %>>
          <%= `${p.praenomen}${motherNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
          <% if (p.birth_year) { %> (<%= p.birth_year %>) <% } %>
        </option>
      <% }) %>
    </select><br><br>

    <button type="submit">Save Changes</button>
  </form>

  <br>
  <a href="/people/<%= person.id %>">Back</a>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
  <script>
    $(document).ready(function() {
      $('.searchable-select').select2({
        placeholder: 'Search...'
      });
    });
  </script>
</body>
</html>