<!DOCTYPE html>
<html>
<head>
  <title>Edit Person</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
  <style>
    .select2-container--default .select2-selection--single {
      border: 1px solid var(--border-color) !important;
      padding: 3px;
      display: flex;
      align-items: center;
      background: var(--bg-primary) !important;
      color: var(--text-primary) !important;
    }
    .select2-container--default .select2-selection--single .select2-selection__rendered {
      padding: 2px;
      display: flex;
      align-items: center;
      min-height: 30px;
      color: var(--text-primary) !important;
    }
    .select2-container--default.select2-container--open .select2-selection--single {
      border: 1px solid var(--text-secondary) !important;
    }
    .select2-dropdown {
      background: var(--bg-primary) !important;
      border: 1px solid var(--border-color) !important;
    }
    .select2-results__option {
      color: var(--text-primary) !important;
    }
    .select2-results__option--highlighted {
      background: var(--bg-secondary) !important;
      color: var(--text-primary) !important;
    }
  </style>
</head>
<body>
  <%- include('navbar') %>

  <main>
    <h1>Edit Person</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="color: #d32f2f; padding: 10px; margin-bottom: 15px; border: 1px solid #d32f2f; background-color: #ffcdd2; border-radius: 4px;">
        <strong>Error:</strong> <%= error %>
      </div>
    <% } %>

  <form method="POST" action="/people/edit/<%= person.id %>">

    <label>Praenomen:</label><br>
    <input type="text" name="praenomen" value="<%= person.praenomen %>" maxlength="100" required><br><br>

    <label>House:</label><br>
    <select name="house_id" class="searchable-select">
      <% houses.forEach(h => { %>
        <option value="<%= h.id %>" <%= h.id === person.house_id ? 'selected' : '' %>>
          <%= h.gens_name %>
        </option>
      <% }) %>
    </select><br><br>

    <label>Sex:</label><br>
    <select name="sex">
      <option value="1" <%= person.sex === 1 ? 'selected' : '' %>>Male</option>
      <option value="0" <%= person.sex === 0 ? 'selected' : '' %>>Female</option>
    </select><br><br>

    <label>Cognomen:</label><br>
    <input type="text" name="cognomen" value="<%= person.cognomen || '' %>" maxlength="100"><br><br>

    <label>Birth Year:</label><br>
    <input type="number" name="birth_year" value="<%= person.birth_year || '' %>"><br><br>

    <label>Death Year:</label><br>
    <input type="number" name="death_year" value="<%= person.death_year || '' %>"><br><br>

    <label>
      <input type="checkbox" name="is_bastard" <%= person.is_bastard ? 'checked' : '' %>>
      Bastard (hide last name in displays)
    </label><br><br>

    <h3>Parents</h3>

    <label>Select Father:</label><br>
    <select name="father_id" class="searchable-select">
      <option value="">None</option>
      <% people.filter(p => p.sex === 1).forEach(p => { %>
        <% const fatherNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, 1)}`; %>
        <option value="<%= p.id %>" <%= father && father.id === p.id ? 'selected' : '' %>>
          <%= `${p.praenomen}${fatherNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
          <% if (p.birth_year) { %> (<%= p.birth_year %>) <% } %>
        </option>
      <% }) %>
    </select><br><br>

    <label>Select Mother:</label><br>
    <select name="mother_id" class="searchable-select">
      <option value="">None</option>
      <% people.filter(p => p.sex === 0).forEach(p => { %>
        <% const motherNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, 0)}`; %>
        <option value="<%= p.id %>" <%= mother && mother.id === p.id ? 'selected' : '' %>>
          <%= `${p.praenomen}${motherNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
          <% if (p.birth_year) { %> (<%= p.birth_year %>) <% } %>
        </option>
      <% }) %>
    </select><br><br>

    <button type="button" id="add-rumored-parent-btn" onclick="addRumoredParentField()">+ Add Rumored Parent</button><br><br>

    <div id="rumored-parents-container" style="<%= allParents && allParents.some(ap => ap.status === 'rumored') ? 'display: block' : 'display: none' %>; margin: 20px 0; padding: 15px; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 5px;">
      <h4>Rumored Parents</h4>
      <div id="rumored-parents-list">
        <% if (allParents && allParents.length > 0) { %>
          <% allParents.forEach((p, index) => { %>
            <% if (p.status === 'rumored') { %>
              <div id="rumored-parent-existing-<%= index %>" style="margin-bottom: 15px; padding: 10px; background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 3px;">
                <label>Rumored Parent:</label><br>
                <select name="rumored_parent_ids" class="searchable-select" style="width: 100%; margin-bottom: 10px;">
                  <option value="">Select a person...</option>
                  <% people.forEach(person => { %>
                    <% const nomen = person.is_bastard ? '' : ` ${genderifyNomen(person.nomen, person.sex)}`; %>
                    <option value="<%= person.id %>" <%= person.id === p.id ? 'selected' : '' %>>
                      <%= `${person.praenomen}${nomen}${person.cognomen ? ' ' + person.cognomen : ''}` %>
                      <% if (person.birth_year) { %> (<%= person.birth_year %>) <% } %>
                    </option>
                  <% }) %>
                </select>
                <button type="button" onclick="removeRumoredParentField('rumored-parent-existing-<%= index %>')" style="background: var(--button-bg); color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">Remove</button>
              </div>
            <% } %>
          <% }) %>
        <% } %>
      </div>
    </div>

    <label>
      <input type="checkbox" name="has_adoptive_parents" id="has-adoptive-parents" <%= adoptiveFather || adoptiveMother ? 'checked' : '' %>>
      Has Adoptive Parents
    </label><br><br>

    <div id="adoptive-parents-section" style="display: <%= adoptiveFather || adoptiveMother ? 'block' : 'none' %>;">
      <h3>Adoptive Parents</h3>

      <label>Adoptive Father:</label><br>
      <select name="adoptive_father_id" class="searchable-select">
        <option value="">None</option>
        <% people.filter(p => p.sex === 1).forEach(p => { %>
          <% const fatherNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, 1)}`; %>
          <option value="<%= p.id %>" <%= adoptiveFather && adoptiveFather.id === p.id ? 'selected' : '' %>>
            <%= `${p.praenomen}${fatherNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
            <% if (p.birth_year) { %> (<%= p.birth_year %>) <% } %>
          </option>
        <% }) %>
      </select><br><br>

      <label>Adoptive Father Status:</label><br>
      <select name="adoptive_father_status">
        <option value="confirmed" <%= adoptiveFather && adoptiveFather.status === 'confirmed' || !adoptiveFather ? 'selected' : '' %>>Confirmed</option>
        <option value="rumored" <%= adoptiveFather && adoptiveFather.status === 'rumored' ? 'selected' : '' %>>Rumored</option>
      </select><br><br>

      <label>Adoptive Mother:</label><br>
      <select name="adoptive_mother_id" class="searchable-select">
        <option value="">None</option>
        <% people.filter(p => p.sex === 0).forEach(p => { %>
          <% const motherNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, 0)}`; %>
          <option value="<%= p.id %>" <%= adoptiveMother && adoptiveMother.id === p.id ? 'selected' : '' %>>
            <%= `${p.praenomen}${motherNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
            <% if (p.birth_year) { %> (<%= p.birth_year %>) <% } %>
          </option>
        <% }) %>
      </select><br><br>

      <label>Adoptive Mother Status:</label><br>
      <select name="adoptive_mother_status">
        <option value="confirmed" <%= adoptiveMother && adoptiveMother.status === 'confirmed' || !adoptiveMother ? 'selected' : '' %>>Confirmed</option>
        <option value="rumored" <%= adoptiveMother && adoptiveMother.status === 'rumored' ? 'selected' : '' %>>Rumored</option>
      </select><br><br>

      <label>Adoptive House (Gens):</label><br>
      <select name="adoptive_house_id" class="searchable-select">
        <option value="">None</option>
        <% houses.forEach(h => { %>
          <option value="<%= h.id %>" <%= person.adoptive_house_id === h.id ? 'selected' : '' %>>
            <%= h.gens_name %>
          </option>
        <% }) %>
      </select><br><br>
    </div>

    <h3>Partners</h3>

    <div id="partnerships-display" style="margin-bottom: 20px;">
      <% if (confirmedPartners && confirmedPartners.length > 0) { %>
        <div style="margin-bottom: 15px;">
          <h4>Confirmed Partners:</h4>
          <ul>
            <% confirmedPartners.forEach(p => { %>
              <li>
                <% const partnerNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
                <%= `${p.praenomen}${partnerNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
                <button type="button" onclick="removePartnershipField(<%= p.id %>)" style="background: var(--button-hover); color: white; border: none; padding: 3px 8px; border-radius: 3px; cursor: pointer; margin-left: 10px;">Remove</button>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>
      <% if (rumoredPartners && rumoredPartners.length > 0) { %>
        <div style="margin-bottom: 15px;">
          <h4>Rumored Partners:</h4>
          <ul>
            <% rumoredPartners.forEach(p => { %>
              <li>
                <% const partnerNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
                <%= `${p.praenomen}${partnerNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
                <button type="button" onclick="removePartnershipField(<%= p.id %>)" style="background: var(--button-hover); color: white; border: none; padding: 3px 8px; border-radius: 3px; cursor: pointer; margin-left: 10px;">Remove</button>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>
    </div>

    <button type="button" id="add-partner-btn" onclick="showAddPartnerField()">+ Add Partner</button><br><br>

    <div id="add-partner-section" style="display: none; margin: 20px 0; padding: 15px; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 5px;">
      <h4>Add New Partner</h4>
      <label>Select Partner:</label><br>
      <select id="new-partner-select" class="searchable-select" style="width: 100%; margin-bottom: 10px;">
        <option value="">Select a person...</option>
        <% people.forEach(p => { %>
          <% if (p.id !== person.id) { %>
            <% const nomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
            <option value="<%= p.id %>">
              <%= `${p.praenomen}${nomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
            </option>
          <% } %>
        <% }) %>
      </select><br><br>

      <label>Partnership Status:</label><br>
      <select id="partner-status-select" style="margin-bottom: 10px;">
        <option value="confirmed">Confirmed</option>
        <option value="rumored">Rumored</option>
      </select><br><br>

      <button type="button" onclick="addNewPartnership(<%= person.id %>)" style="background: var(--button-bg); color: white; border: none; padding: 8px 12px; border-radius: 3px; cursor: pointer; margin-right: 5px;">Add Partnership</button>
      <button type="button" onclick="hideAddPartnerField()" style="background: var(--button-hover); color: white; border: none; padding: 8px 12px; border-radius: 3px; cursor: pointer;">Cancel</button>
    </div>

    <hr style="margin: 30px 0;">

    <button type="submit">Save Changes</button>
  </form>

  <br>
  <a href="/people/<%= person.id %>">Back</a>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
  <script>
    // Pre-populate people data for JavaScript use
    const peopleData = [
      <% people.forEach((p, idx) => { %>
        {
          id: <%= p.id %>,
          praenomen: '<%= p.praenomen %>',
          nomen: '<%= p.is_bastard ? '' : genderifyNomen(p.nomen, p.sex) %>',
          cognomen: '<%= p.cognomen || '' %>',
          birth_year: <%= p.birth_year || 'null' %>
        }<%= idx < people.length - 1 ? ',' : '' %>
      <% }) %>
    ];

    $(document).ready(function() {
      $('.searchable-select').select2({
        placeholder: 'Search...'
      });

      $('#has-adoptive-parents').change(function() {
        if (this.checked) {
          $('#adoptive-parents-section').show();
        } else {
          $('#adoptive-parents-section').hide();
        }
      });
    });

    let rumoredParentCount = 0;

    function addRumoredParentField() {
      const container = document.getElementById('rumored-parents-container');
      container.style.display = 'block';

      const listContainer = document.getElementById('rumored-parents-list');
      const fieldId = 'rumored-parent-' + rumoredParentCount;

      let optionsHtml = '<option value="">None</option>';
      peopleData.forEach(p => {
        const fullName = p.praenomen + (p.nomen ? ' ' + p.nomen : '') + (p.cognomen ? ' ' + p.cognomen : '');
        const birthYear = p.birth_year ? ' (' + p.birth_year + ')' : '';
        optionsHtml += `<option value="${p.id}">${fullName}${birthYear}</option>`;
      });

      const fieldHtml = `
        <div id="${fieldId}" style="margin-bottom: 15px; padding: 10px; background: white; border: 1px solid #e0e0e0; border-radius: 3px;">
          <label>Rumored Parent:</label><br>
          <select name="rumored_parent_ids" class="searchable-select" style="width: 100%; margin-bottom: 10px;">
            ${optionsHtml}
          </select>
          <button type="button" onclick="removeRumoredParentField('${fieldId}')" style="background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">Remove</button>
        </div>
      `;

      listContainer.insertAdjacentHTML('beforeend', fieldHtml);
      
      // Reinitialize select2 for new dropdown
      $(`#${fieldId} .searchable-select`).select2({
        placeholder: 'Search...'
      });

      rumoredParentCount++;
    }

    function removeRumoredParentField(fieldId) {
      const field = document.getElementById(fieldId);
      field.remove();

      // Hide container if no rumored parents left
      const listContainer = document.getElementById('rumored-parents-list');
      if (listContainer.children.length === 0) {
        document.getElementById('rumored-parents-container').style.display = 'none';
      }
    }

    function showAddPartnerField() {
      document.getElementById('add-partner-section').style.display = 'block';
      $('#new-partner-select').select2({
        placeholder: 'Search...'
      });
    }

    function hideAddPartnerField() {
      document.getElementById('add-partner-section').style.display = 'none';
      $('#new-partner-select').val(null).trigger('change');
    }

    function addNewPartnership(personId) {
      const partnerId = document.getElementById('new-partner-select').value;
      const status = document.getElementById('partner-status-select').value;

      if (!partnerId) {
        alert('Please select a partner');
        return;
      }

      fetch('/partnership/add', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          person1_id: personId,
          person2_id: parseInt(partnerId),
          status: status
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          location.reload();
        } else {
          alert('Error adding partnership: ' + data.error);
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error adding partnership');
      });
    }

    function removePartnershipField(partnerId) {
      if (confirm('Are you sure you want to remove this partnership?')) {
        const personId = <%= person.id %>;
        fetch(`/partnership/remove/${personId}/${partnerId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            location.reload();
          } else {
            alert('Error removing partnership: ' + data.error);
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('Error removing partnership');
        });
      }
    }
  </script>
  </main>
</body>
</html>