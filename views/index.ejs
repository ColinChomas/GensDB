<!DOCTYPE html>
<html>
<head>
  <title>Roman Family Tree</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body {
      padding-top: 0;
    }

    .page-content {
      padding: 30px 20px;
      max-width: 1400px;
      margin: 0 auto;
    }

    h1 {
      margin: 20px 0 30px 0;
      color: var(--text-secondary);
    }

    h2 {
      color: var(--text-secondary);
      margin-top: 25px;
      margin-bottom: 15px;
    }

    .houses-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .house-card {
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      box-shadow: 0 2px 8px var(--card-shadow);
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .house-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 6px 16px var(--card-shadow);
    }

    .house-card h3 {
      font-size: 20px;
      color: var(--text-secondary);
      margin-bottom: 15px;
      border-bottom: 2px solid var(--border-color);
      padding-bottom: 10px;
    }

    .house-card-content {
      font-size: 14px;
      margin-bottom: 15px;
    }

    .house-card-content p {
      margin: 10px 0;
      color: var(--text-primary);
    }

    .founder-label {
      font-weight: bold;
      color: var(--text-secondary);
    }

    .founder-link {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
    }

    .founder-link:hover {
      text-decoration: underline;
    }

    .house-card-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 15px;
    }

    .house-card-actions a {
      flex: 1;
      min-width: 120px;
      padding: 10px 15px;
      background: var(--button-bg);
      color: #fefcf8;
      text-decoration: none;
      border-radius: 4px;
      text-align: center;
      transition: background-color 0.3s;
      font-size: 13px;
      font-weight: 500;
    }

    .house-card-actions a:hover {
      background: var(--button-hover);
    }

    .no-houses {
      background: var(--bg-secondary);
      padding: 20px;
      border-radius: 4px;
      border-left: 4px solid var(--text-secondary);
      font-size: 16px;
      color: var(--text-primary);
    }

    .no-houses a {
      color: var(--text-secondary);
    }
  </style>
</head>
<body>

  <%- include('navbar') %>

  <!-- Main Content -->
  <div class="page-content">
    <h1>Welcome to the Roman Family Tree System</h1>

    <h2>Houses (Gentes)</h2>
    
    <% if (houses.length > 0) { %>
      <div class="houses-grid">
        <% houses.forEach(h => { %>
          <div class="house-card">
            <h3><%= h.gens_name %></h3>
            
            <div class="house-card-content">
              <% if (h.founder) { %>
                <p>
                  <span class="founder-label">Founder:</span>
                  <a href="/people/<%= h.founder.id %>" class="founder-link">
                    <%= h.founder.praenomen %> <%= genderifyNomen(h.founder.nomen, h.founder.sex) %>
                    <% if (h.founder.cognomen) { %><%= h.founder.cognomen %><% } %>
                  </a>
                </p>
              <% } else { %>
                <p><span class="founder-label">Founder:</span> <em>Not set</em></p>
              <% } %>
            </div>

            <div class="house-card-actions">
              <% if (h.founder_id) { %>
                <a href="/tree/<%= h.id %>">View Tree</a>
              <% } %>
              <a href="/houses/edit/<%= h.id %>">Edit House</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="no-houses">
        No houses yet. <a href="/houses/add">Create the first house!</a>
      </div>
    <% } %>
  </div>

</body>
</html>