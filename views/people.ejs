<!DOCTYPE html>
<html>
<head>
  <title>People</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1>People</h1>

  <a href="/">← Back</a> |
  <a href="/people/add">Add Person</a>

  <table border="1" cellpadding="6" cellspacing="0">
    <tr>
      <th>Full Name</th>
      <th>House (Gens)</th>
      <th>Sex</th>
      <th>Cognomen</th>
      <th>Actions</th>
    </tr>

    <% people.forEach(p => { %>
      <% 
        // Find the house for this person
        const house = houses.find(h => h.id === p.house_id);

        // Gender-corrected nomen (Julius / Julia)
        const nomen = p.is_bastard ? '' : genderifyNomen(house.gens_name, p.sex);

        // Build full Roman name
        const fullName = `${p.praenomen}${nomen ? ' ' + nomen : ''}${p.cognomen ? ' ' + p.cognomen : ''}`;
      %>

      <tr>
        <td><%= fullName %></td>

        <!-- Raw gens name (Julia, Cornelia, etc.) -->
        <td><%= house.gens_name %></td>

        <td><%= p.sex === 1 ? 'Male' : 'Female' %></td>

        <td><%= p.cognomen || '' %></td>

        <td>
          <a href="/people/edit/<%= p.id %>">Edit</a>
        </td>
      </tr>
    <% }) %>
  </table>
</body>
</html>