<!DOCTYPE html>
<html>
<head>
  <title>People</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .filter-section {
      margin-bottom: 20px;
      padding: 15px;
      background: #f5f5f5;
      border-radius: 5px;
    }
    .filter-section h3 {
      margin-top: 0;
    }
    .filter-group {
      display: inline-block;
      margin-right: 20px;
      margin-bottom: 10px;
    }
    .filter-group label {
      margin-right: 8px;
      font-weight: bold;
    }
    .filter-group input,
    .filter-group select {
      padding: 5px 8px;
      border: 1px solid #ccc;
      border-radius: 3px;
    }
    button.reset-filters {
      padding: 5px 15px;
      background: #666;
      color: white;
      border: none;
      border-radius: 3px;
      cursor: pointer;
    }
    button.reset-filters:hover {
      background: #444;
    }
  </style>
</head>
<body>
  <%- include('navbar') %>

  <main>
    <h1>People</h1>

    <a href="/">← Back</a> |
    <a href="/people/add">Add Person</a>

  <div class="filter-section">
    <h3>Filters</h3>
    <div class="filter-group">
      <label for="filterName">Name:</label>
      <input type="text" id="filterName" placeholder="Search by name...">
    </div>
    <div class="filter-group">
      <label for="filterSex">Sex:</label>
      <select id="filterSex">
        <option value="">All</option>
        <option value="Male">Male</option>
        <option value="Female">Female</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="filterHouse">House:</label>
      <select id="filterHouse">
        <option value="">All</option>
        <% houses.forEach(h => { %>
          <option value="<%= h.gens_name %>"><%= h.gens_name %></option>
        <% }) %>
      </select>
    </div>
    <button class="reset-filters" onclick="resetFilters()">Reset Filters</button>
  </div>

  <table border="1" cellpadding="6" cellspacing="0" id="peopleTable">
    <tr>
      <th>Full Name</th>
      <th>House (Gens)</th>
      <th>Sex</th>
      <th>Cognomen</th>
      <th>Actions</th>
    </tr>

    <% people.forEach(p => { %>
      <% 
        // Find the house for this person
        const birthHouse = houses.find(h => h.id === p.house_id);
        const adoptiveHouse = p.adoptive_house_id ? houses.find(h => h.id === p.adoptive_house_id) : null;
        
        // Use adoptive house if available, otherwise birth house
        const displayHouse = adoptiveHouse || birthHouse;

        // Gender-corrected nomen (Julius / Julia)
        const nomen = p.is_bastard ? '' : genderifyNomen(displayHouse.gens_name, p.sex);

        // Build full Roman name
        const fullName = `${p.praenomen}${nomen ? ' ' + nomen : ''}${p.cognomen ? ' ' + p.cognomen : ''}`;
      %>

      <tr class="people-row" data-name="<%= fullName.toLowerCase() %>" data-sex="<%= p.sex === 1 ? 'Male' : 'Female' %>" data-house="<%= displayHouse.gens_name %>">
        <td><a href="/people/<%= p.id %>"><%= fullName %></a></td>

        <!-- Raw gens name (Julia, Cornelia, etc.) -->
        <td><%= displayHouse.gens_name %><% if (adoptiveHouse) { %> (adopted)<% } %></td>

        <td><%= p.sex === 1 ? 'Male' : 'Female' %></td>

        <td><%= p.cognomen || '' %></td>

        <td>
          <a href="/people/edit/<%= p.id %>">Edit</a>
        </td>
      </tr>
    <% }) %>
  </table>

  <script>
    const filterName = document.getElementById('filterName');
    const filterSex = document.getElementById('filterSex');
    const filterHouse = document.getElementById('filterHouse');

    function applyFilters() {
      const nameFilter = filterName.value.toLowerCase();
      const sexFilter = filterSex.value;
      const houseFilter = filterHouse.value;

      const rows = document.querySelectorAll('.people-row');
      
      rows.forEach(row => {
        const name = row.dataset.name;
        const sex = row.dataset.sex;
        const house = row.dataset.house;

        const matchesName = name.includes(nameFilter);
        const matchesSex = !sexFilter || sex === sexFilter;
        const matchesHouse = !houseFilter || house === houseFilter;

        if (matchesName && matchesSex && matchesHouse) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    }

    function resetFilters() {
      filterName.value = '';
      filterSex.value = '';
      filterHouse.value = '';
      applyFilters();
    }

    filterName.addEventListener('input', applyFilters);
    filterSex.addEventListener('change', applyFilters);
    filterHouse.addEventListener('change', applyFilters);
  </script>
  </main>
</body>
</html>