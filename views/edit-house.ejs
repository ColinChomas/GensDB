<!DOCTYPE html>
<html>
<head>
  <title>Edit House</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('navbar') %>

  <main>
    <h1>Edit Gens <%= house.gens_name %></h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="color: #d32f2f; padding: 10px; margin-bottom: 15px; border: 1px solid #d32f2f; background-color: #ffcdd2; border-radius: 4px;">
        <strong>Error:</strong> <%= error %>
      </div>
    <% } %>

    <a href="/houses">← Back</a>

  <hr>

  <h2>📥 Export House Data</h2>
  <p>Download all members of this house as a CSV file to share with others.</p>
  <a href="/houses/<%= house.id %>/export-csv" style="display: inline-block; padding: 10px 20px; background: var(--button-bg); color: white; text-decoration: none; border-radius: 4px; margin-bottom: 20px;">
    Download CSV
  </a>

  <h2>📤 Import House Data</h2>
  <p>Upload a CSV file to add members to this house and their family relationships. The CSV should have the format:</p>
  <div style="background: var(--bg-secondary); padding: 10px; border-radius: 4px; margin: 10px 0; font-family: monospace; font-size: 12px; overflow-x: auto; border: 1px solid var(--border-color);">
    temp_id,praenomen,nomen,cognomen,sex,is_bastard,birth_year,death_year,father_temp_id,mother_temp_id
  </div>
  <p style="font-size: 13px; color: var(--text-primary);"><strong>Note:</strong> Use <code>temp_id</code> to link family relationships (matching IDs from original export). Relationships can also link to parents by using their actual database IDs. Leave father/mother fields blank if unknown.</p>

  <form method="POST" action="/houses/<%= house.id %>/import-csv" enctype="multipart/form-data">
    <label for="csv-file"><strong>Select CSV file:</strong></label><br>
    <input type="file" id="csv-file" name="csv-file" accept=".csv" required style="padding: 8px; margin: 8px 0;"><br>
    <button type="submit" style="padding: 10px 20px; background: var(--button-bg); color: white; border: none; border-radius: 4px; cursor: pointer;">
      Import Members
    </button>
  </form>

  <% if (locals.message) { %>
    <% const isError = message.type === 'error'; %>
    <div style="background: var(--bg-secondary); padding: 15px; border-radius: 4px; margin: 15px 0; border-left: 3px solid var(--text-secondary);">
      <strong><%= isError ? 'Error' : 'Success' %>:</strong> <%= message.text %>
      <% if (message.details) { %>
        <br><small><%= message.details %></small>
      <% } %>
    </div>
  <% } %>

  <hr>

  <h2>Set Founder</h2>

  <form method="POST" action="/houses/edit/<%= house.id %>">
    <label>Select Founder:</label><br>
    <select name="founder_id">
      <option value="">None</option>

      <% people.forEach(p => { %>
        <% 
          const nomen = p.is_bastard ? '' : genderifyNomen(
            people.find(x => x.id === p.id).nomen || house.gens_name,
            p.sex
          );
        %>
        <option value="<%= p.id %>" <%= p.id === house.founder_id ? 'selected' : '' %>>
          <%= `${p.praenomen}${nomen ? ' ' + nomen : ''}${p.cognomen ? ' ' + p.cognomen : ''}` %>
          <% if (p.birth_year) { %> (<%= p.birth_year %>) <% } %>
        </option>
      <% }) %>
    </select><br><br>

    <button type="submit">Save Founder</button>
  </form>

  <hr>

  <h2>Create New Founder</h2>

  <form method="POST" action="/houses/create-founder/<%= house.id %>">

    <label>Praenomen:</label><br>
    <input type="text" name="praenomen" maxlength="100" required><br><br>

    <label>Sex:</label><br>
    <select name="sex">
      <option value="1">Male</option>
      <option value="0">Female</option>
    </select><br><br>

    <label>Cognomen (optional):</label><br>
    <input type="text" name="cognomen" maxlength="100"><br><br>

    <label>Birth Year:</label><br>
    <input type="number" name="birth_year"><br><br>

    <label>Death Year:</label><br>
    <input type="number" name="death_year"><br><br>

    <button type="submit">Create Founder</button>
  </form>

  <hr style="margin: 40px 0;">

  <h2 style="color: #d32f2f;">⚠️ Danger Zone</h2>

  <p style="color: #d32f2f; margin: 20px 0;"><strong>Delete House</strong></p>
  <p>Permanently delete this house and <strong>all</strong> of its members and relationships. This cannot be undone.</p>
  
  <form method="POST" action="/houses/<%= house.id %>/delete" style="display: inline;">
    <button type="submit" onclick="return confirm('Are you sure you want to delete this entire house \"<%= house.gens_name %>\" and all its members? This cannot be undone.');" style="padding: 10px 20px; background: #d32f2f; color: white; border: none; border-radius: 4px; cursor: pointer;">
      Delete House and All Members
    </button>
  </form>

  </main>

</body>
</html>