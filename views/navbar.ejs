    <select id="themeSelector" class="theme-dropdown" title="Select Theme">
      <option value="light-parchment">🏛️ Light Parchment</option>
      <option value="dark-parchment">🌙 Dark Parchment</option>
      <option value="light-traditional">☀️ Light Traditional</option>
      <option value="dark-traditional">🌑 Dark Traditional</option>
    </select>
