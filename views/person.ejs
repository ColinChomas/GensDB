<!DOCTYPE html>
<html>
<head>
  <title><%= person.praenomen %><%= nomen ? ' ' + nomen : '' %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('navbar') %>

  <main>
    <h1>
      <%= person.praenomen %><%= nomen ? ' ' + nomen : '' %>
      <% if (person.cognomen) { %> <%= person.cognomen %> <% } %>
      <%= formatRomanDate(person.birth_year, person.death_year) %>
    </h1>

  <p><strong>Birth House (Gens):</strong> <%= house.gens_name %></p>
  <% if (adoptiveHouse) { %>
    <p><strong>Adoptive House (Gens):</strong> <%= adoptiveHouse.gens_name %></p>
  <% } %>
  <p><strong>Sex:</strong> <%= person.sex === 1 ? 'Male' : 'Female' %></p>

  <% if (inbreedingData || ancestralInbreedingData) { %>
    <div style="display: flex; gap: 15px; margin: 15px 0; flex-wrap: wrap;">
      <% if (inbreedingData) { %>
        <div style="flex: 1; min-width: 250px; background: #f5ede2; padding: 12px; border-radius: 4px; border-left: 3px solid #6b5038;">
          <strong>Inbreeding Coefficient:</strong> <span style="font-size: 16px; font-weight: bold; color: #6b5038;"><%= inbreedingData.percentage %></span>
          <br><em style="font-size: 13px;"><%= inbreedingData.description %></em>
          <% if (inbreedingData.commonAncestors > 0) { %>
            <br><small style="color: #3a2415;"><%= inbreedingData.commonAncestors %> common ancestor(s) between parents</small>
          <% } %>
        </div>
      <% } %>

      <% if (ancestralInbreedingData) { %>
        <div style="flex: 1; min-width: 250px; background: #f5ede2; padding: 12px; border-radius: 4px; border-left: 3px solid #8b7355;">
          <strong>Ancestral Genetic Load:</strong> <span style="font-size: 16px; font-weight: bold; color: #8b7355;"><%= ancestralInbreedingData.percentage %></span>
          <br><em style="font-size: 13px;"><%= ancestralInbreedingData.description %></em>
          <% if (ancestralInbreedingData.ancestorsAnalyzed > 0) { %>
            <br><small style="color: #3a2415;"><%= ancestralInbreedingData.ancestorsAnalyzed %> ancestors analyzed</small>
          <% } %>
        </div>
      <% } %>
    </div>
  <% } %>

  <hr>

  <h2>Parents</h2>
  <% if (confirmedParents.length === 0 && rumoredParents.length === 0 && confirmedAdoptiveParents.length === 0 && rumoredAdoptiveParents.length === 0) { %>
    <p>No parents recorded.</p>
  <% } else { %>
    <% if (confirmedParents.length > 0 || rumoredParents.length > 0) { %>
      <h3>Biological Parents</h3>
      <% if (confirmedParents.length > 0) { %>
        <h4>Confirmed</h4>
        <ul>
          <% confirmedParents.forEach(p => { %>
            <li>
              <% const parentNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
              <a href="/people/<%= p.id %>">
                <%= `${p.praenomen}${parentNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
              </a>
              <%= formatRomanDate(p.birth_year, p.death_year) %>
            </li>
          <% }) %>
        </ul>
      <% } %>
      <% if (rumoredParents.length > 0) { %>
        <h4>Rumored</h4>
        <ul>
          <% rumoredParents.forEach(p => { %>
            <li>
              <% const parentNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
              <a href="/people/<%= p.id %>">
                <%= `${p.praenomen}${parentNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
              </a>
              <%= formatRomanDate(p.birth_year, p.death_year) %>
            </li>
          <% }) %>
        </ul>
      <% } %>
    <% } %>

    <% if (confirmedAdoptiveParents.length > 0 || rumoredAdoptiveParents.length > 0) { %>
      <h3>Adoptive Parents</h3>
      <% if (confirmedAdoptiveParents.length > 0) { %>
        <h4>Confirmed</h4>
        <ul>
          <% confirmedAdoptiveParents.forEach(p => { %>
            <li>
              <% const parentNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
              <a href="/people/<%= p.id %>">
                <%= `${p.praenomen}${parentNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
              </a>
              <%= formatRomanDate(p.birth_year, p.death_year) %>
            </li>
          <% }) %>
        </ul>
      <% } %>
      <% if (rumoredAdoptiveParents.length > 0) { %>
        <h4>Rumored</h4>
        <ul>
          <% rumoredAdoptiveParents.forEach(p => { %>
            <li>
              <% const parentNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
              <a href="/people/<%= p.id %>">
                <%= `${p.praenomen}${parentNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
              </a>
              <%= formatRomanDate(p.birth_year, p.death_year) %>
            </li>
          <% }) %>
        </ul>
      <% } %>
    <% } %>
  <% } %>

  <h2>Children</h2>
  <% if (children.length === 0) { %>
    <p>No children recorded.</p>
  <% } else { %>
    <ul>
      <% children.forEach(c => { %>
        <li>
          <% const childNomen = c.is_bastard ? '' : ` ${genderifyNomen(c.nomen, c.sex)}`; %>
          <a href="/people/<%= c.id %>">
            <%= `${c.praenomen}${childNomen}${c.cognomen ? ' ' + c.cognomen : ''}` %>
          </a>
          <%= formatRomanDate(c.birth_year, c.death_year) %>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <h2>Siblings</h2>
  <% if (siblings.length === 0) { %>
    <p>No siblings recorded.</p>
  <% } else { %>
    <ul>
      <% siblings.forEach(s => { %>
        <li>
          <% const siblingNomen = s.is_bastard ? '' : ` ${genderifyNomen(s.nomen, s.sex)}`; %>
          <a href="/people/<%= s.id %>">
            <%= `${s.praenomen}${siblingNomen}${s.cognomen ? ' ' + s.cognomen : ''}` %>
          </a>
          <%= formatRomanDate(s.birth_year, s.death_year) %>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <h2>Partners</h2>
  <% if (partners.length === 0 && rumoredPartners.length === 0) { %>
    <p>No partners recorded.</p>
  <% } else { %>
    <% if (partners.length > 0) { %>
      <h3>Confirmed</h3>
      <ul>
        <% partners.forEach(p => { %>
          <li>
            <% const partnerNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
            <a href="/people/<%= p.id %>">
              <%= `${p.praenomen}${partnerNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
            </a>
            <%= formatRomanDate(p.birth_year, p.death_year) %>
          </li>
        <% }) %>
      </ul>
    <% } %>
    <% if (rumoredPartners.length > 0) { %>
      <h3>Rumored</h3>
      <ul>
        <% rumoredPartners.forEach(p => { %>
          <li>
            <% const partnerNomen = p.is_bastard ? '' : ` ${genderifyNomen(p.nomen, p.sex)}`; %>
            <a href="/people/<%= p.id %>">
              <%= `${p.praenomen}${partnerNomen}${p.cognomen ? ' ' + p.cognomen : ''}` %>
            </a>
            <%= formatRomanDate(p.birth_year, p.death_year) %>
          </li>
        <% }) %>
      </ul>
    <% } %>
  <% } %>

  <hr>

  <div style="margin-bottom: 15px;">
    <button type="button" id="family-tree-btn" onclick="openFamilyTreeModal()" style="background: #6b5038; color: #fff; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: 500; margin-right: 10px;">📊 View Family Tree</button>
  </div>
  
  <a href="/people/edit/<%= person.id %>">Edit Person</a> |
  <a href="/people/<%= person.id %>/relationships">View All Relationships</a> |
  <a href="/tree/<%= house.id %>">View Full House Tree</a> |
  <a href="/people">Back to People</a>

  <!-- Family Tree Modal -->
  <div id="family-tree-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 1000; overflow: auto;">
    <div style="background: #fefcf8; margin: 20px auto; padding: 20px; border-radius: 6px; max-width: 95%; border: 1px solid #b59d8a; position: relative;">
      <button type="button" onclick="closeFamilyTreeModal()" style="position: absolute; top: 10px; right: 10px; background: #6b5038; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">Close</button>
      <h2 style="margin-top: 0;">Family Tree - <%= person.praenomen %></h2>
      <div id="family-tree-content"></div>
    </div>
  </div>

  <script>
    function openFamilyTreeModal() {
      document.getElementById('family-tree-modal').style.display = 'block';
      
      // Fetch the limited family tree from the server
      fetch(`/people/<%= person.id %>/family-tree-limited`)
        .then(response => response.text())
        .then(treeHtml => {
          document.getElementById('family-tree-content').innerHTML = treeHtml;
        })
        .catch(error => {
          document.getElementById('family-tree-content').innerHTML = '<p>Error loading family tree</p>';
        });
    }

    function closeFamilyTreeModal() {
      document.getElementById('family-tree-modal').style.display = 'none';
    }

    // Close modal when clicking outside of it
    window.onclick = function(event) {
      const modal = document.getElementById('family-tree-modal');
      if (event.target == modal) {
        modal.style.display = 'none';
      }
    }
  </script>

</body>
</html>