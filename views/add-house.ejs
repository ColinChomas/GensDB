<!DOCTYPE html>
<html>
<head>
  <title>Add House</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('navbar') %>

  <main>
    <h1>Add a New Gens (House)</h1>

    <form method="POST" action="/houses/add">
      <label>Gens Name:</label><br>
      <input type="text" name="gens_name" required><br><br>

      <button type="submit">Create House</button>
    </form>

    <br>
    <a href="/houses">Back</a>
  </main>
</body>
</html>